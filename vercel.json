{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "Index.html",
      "use": "@vercel/static"
    },
    {
      "src": "Login.html",
      "use": "@vercel/static"
    },
    {
      "src": "doctor.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/main.py"
    },
    {
      "src": "/doctor.png",
      "dest": "/doctor.png"
    },
    {
      "src": "/login",
      "dest": "/Login.html"
    },
    {
      "src": "/chat",
      "dest": "/Index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/Login.html"
    }
  ]
}
